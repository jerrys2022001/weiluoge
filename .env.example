# X API credentials (User context with Read and write permission)
X_API_KEY=your_api_key
X_API_KEY_SECRET=your_api_key_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# Optional override
# X_API_BASE_URL=https://api.x.com

# Optional Playwright overrides
# X_PLAYWRIGHT_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# X_PLAYWRIGHT_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Google\Chrome\User Data
# X_PLAYWRIGHT_PROFILE_DIRECTORY=Default
